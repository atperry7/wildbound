	"authors": [
		"Cadaewen"
	],
	"license": "MIT",
	"icon": "assets/wildbound/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.cadaewen.wildbound.Wildbound"
		],
		"client": [
			"com.cadaewen.wildbound.client.WildboundClient"
		]
	},
	"mixins": [
		"wildbound.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~26.1.2",
		"java": ">=25",
		"fabric-api": "*"
	}
